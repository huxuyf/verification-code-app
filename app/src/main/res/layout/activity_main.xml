<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#F5F5F5">

    <!-- 应用标题 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="验证码短信助手"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:gravity="center"
        android:layout_marginTop="48dp"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="自动提取并显示短信验证码"
        android:textSize="16sp"
        android:textColor="#666666"
        android:gravity="center"
        android:layout_marginBottom="32dp" />

    <!-- 权限状态显示 -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="正在检查权限..."
        android:textSize="14sp"
        android:textColor="#333333"
        android:padding="16dp"
        android:background="#FFFFFF"
        android:layout_marginBottom="24dp" />

    <!-- 权限说明 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="应用需要以下权限才能正常工作："
        android:textSize="14sp"
        android:textColor="#666666"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="• 短信权限：用于接收和读取短信内容\n• 悬浮窗权限：用于显示验证码弹窗"
        android:textSize="14sp"
        android:textColor="#666666"
        android:padding="12dp"
        android:background="#FFFFFF"
        android:layout_marginBottom="32dp" />

    <!-- 按钮区域 -->
    <Button
        android:id="@+id/btnRequestPermissions"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="授予权限"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:background="@drawable/main_button_bg"
        android:layout_marginBottom="16dp"
        android:elevation="4dp" />

    <Button
        android:id="@+id/btnStartService"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="开始监听"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:background="@drawable/start_button_bg"
        android:layout_marginBottom="16dp"
        android:enabled="false"
        android:elevation="4dp" />

    <Button
        android:id="@+id/btnStopService"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="停止监听"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:background="@drawable/stop_button_bg"
        android:enabled="false"
        android:elevation="4dp" />

    <!-- 隐私说明 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="隐私说明：本应用仅在本地处理短信数据，不会收集或上传任何信息。"
        android:textSize="12sp"
        android:textColor="#999999"
        android:gravity="center"
        android:layout_marginTop="32dp" />

</LinearLayout>
