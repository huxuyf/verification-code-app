<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/floating_window_bg"
    android:padding="24dp"
    android:gravity="center">

    <!-- 关闭按钮 -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="验证码"
            android:textSize="16sp"
            android:textColor="#666666"
            android:gravity="center"
            android:layout_gravity="center" />

        <TextView
            android:id="@+id/btnClose"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="✕"
            android:textSize="20sp"
            android:textColor="#999999"
            android:gravity="center"
            android:layout_gravity="end|center_vertical"
            android:background="@drawable/close_button_bg" />
    </FrameLayout>

    <!-- 验证码显示 -->
    <TextView
        android:id="@+id/tvVerificationCode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="123456"
        android:textSize="42sp"
        android:textStyle="bold"
        android:textColor="#2196F3"
        android:letterSpacing="0.2"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="24dp"
        android:padding="16dp"
        android:background="@drawable/code_background" />

    <!-- 复制按钮 -->
    <Button
        android:id="@+id/btnCopy"
        android:layout_width="200dp"
        android:layout_height="48dp"
        android:text="复制验证码"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:background="@drawable/copy_button_bg"
        android:elevation="4dp" />

</LinearLayout>
